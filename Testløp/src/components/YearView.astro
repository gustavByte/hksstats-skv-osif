---
import stats from "../data/stats.json";
import ResultTable from "./ResultTable.astro";
import { href, genderShort, type ResultRow } from "../lib/format";

const { year, results } = Astro.props as {
  year: number | "all";
  results: ResultRow[];
};

const isAllYears = year === "all";
const numericYear = typeof year === "number" ? year : null;
const stat = numericYear == null ? null : stats.yearStats.find((item) => item.year === numericYear);
const resultCount = isAllYears ? stats.totals.results : stat?.resultCount ?? 0;
const personCount = isAllYears ? stats.totals.people : stat?.personCount ?? 0;
const testlopCount = isAllYears ? stats.totals.testlop : stat?.testlopCount ?? 0;
const title = isAllYears ? "Alle år" : String(year);
const isSoFarYear = numericYear === 2026;
const quickFilters = [
  { label: "600 K", distance: "600", gender: "Kvinner" },
  { label: "600 M", distance: "600", gender: "Menn" },
  { label: "1200 K", distance: "1200", gender: "Kvinner" },
  { label: "1200 M", distance: "1200", gender: "Menn" },
  { label: "Alle", distance: "all", gender: "all" },
];
---

<section data-year-view>
  <div class="page-head">
    <div>
      <h1 class="page-title">
        <span>{title}</span>
        {isSoFarYear && <span class="year-status">so far</span>}
      </h1>
      <div class="meta-line">
        <span>{resultCount} resultater</span>
        <span>{personCount} personer</span>
        <span>{testlopCount} testløp</span>
        {isSoFarYear && <span>foreløpig status</span>}
        <span><span data-visible-count>{results.length}</span> vist</span>
      </div>
    </div>
  </div>

  <div class="toolbar" aria-label="Filtre">
    <div class="toolbar-group">
      {stats.years.map((item) => {
        const itemStat = stats.yearStats.find((candidate) => candidate.year === item);
        return (
          <a
            class:list={["chip", item === numericYear && "is-active", itemStat?.resultCount === 0 && "is-muted"]}
            href={href(`/aar/${item}/`)}
          >
            <span>{item}</span>
            {item === 2026 && <span class="chip-note">so far</span>}
          </a>
        );
      })}
      <a class:list={["chip", isAllYears && "is-active"]} href={href("/aar/alle/")}>Alle</a>
    </div>
    <div class="toolbar-spacer"></div>
    <div class="toolbar-group toolbar-group-primary" aria-label="Hurtigvalg">
      {quickFilters.map((filter) => (
        <button
          class:list={["chip", filter.distance === "600" && filter.gender === "Menn" && "is-active"]}
          data-filter-preset
          data-distance-value={filter.distance}
          data-gender-value={filter.gender}
          aria-pressed={filter.distance === "600" && filter.gender === "Menn" ? "true" : "false"}
        >
          {filter.label}
        </button>
      ))}
    </div>
    <div class="toolbar-group mobile-hide-filter">
      {[600, 1200].map((distance) => (
        <button class:list={["chip", distance === 600 && "is-active"]} data-filter-name="distance" data-filter-value={String(distance)} aria-pressed={distance === 600 ? "true" : "false"}>
          {distance} m
        </button>
      ))}
      <button class="chip" data-filter-name="distance" data-filter-value="all" aria-pressed="false">Alle</button>
    </div>
    <div class="toolbar-group mobile-hide-filter">
      {["Kvinner", "Menn"].map((gender) => (
        <button class:list={["chip", gender === "Menn" && "is-active"]} data-filter-name="gender" data-filter-value={gender} aria-pressed={gender === "Menn" ? "true" : "false"}>{genderShort(gender)}</button>
      ))}
      <button class="chip" data-filter-name="gender" data-filter-value="all" aria-pressed="false">Alle</button>
    </div>
    <div class="toolbar-group">
      <button class="chip is-active" data-filter-name="mode" data-filter-value="best" aria-pressed="true">Årsbeste</button>
      <button class="chip" data-filter-name="mode" data-filter-value="all" aria-pressed="false">Alle resultater</button>
    </div>
    <label class="screen-reader" for={`search-${year}`}>Søk</label>
    <input class="text-input" id={`search-${year}`} data-search type="search" placeholder="Søk" />
  </div>

  <ResultTable results={results} emptyText={isAllYears ? "Ingen resultater." : "Ingen resultater for dette året ennå."} tableClass="result-table year-results" />
</section>
