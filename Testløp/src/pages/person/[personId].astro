---
import Layout from "../../layouts/Layout.astro";
import ResultTable from "../../components/ResultTable.astro";
import people from "../../data/people.json";
import results from "../../data/results.json";
import stats from "../../data/stats.json";
import { bestValid, displayTime, secondsDelta, type ResultRow } from "../../lib/format";

export function getStaticPaths() {
  return people.map((person) => ({
    params: { personId: person.personId },
    props: { person }
  }));
}

const { person } = Astro.props;
const personResults = (results as ResultRow[])
  .filter((result) => result.personId === person.personId)
  .sort((a, b) => (a.year - b.year) || (a.date || "").localeCompare(b.date || ""));

const summaries = [600, 1200].map((distance) => {
  const rows = personResults.filter((result) => result.distance === distance && result.validToplist);
  const first = [...rows].sort((a, b) => (a.date || "").localeCompare(b.date || ""))[0] || null;
  const best = bestValid(rows);
  return {
    distance,
    first,
    best,
    delta: first && best ? secondsDelta(first.timeSeconds, best.timeSeconds) : null
  };
});

const years = [...stats.years].sort((a, b) => a - b);
const yearBestRows = [600, 1200].map((distance) => {
  const distanceRows = personResults.filter((result) => result.distance === distance && result.validToplist);
  const cells = Object.fromEntries(
    years.map((year) => [
      year,
      bestValid(distanceRows.filter((result) => result.year === year))
    ])
  );
  return {
    distance,
    cells,
    pb: bestValid(distanceRows)
  };
});
---

<Layout title={person.name}>
  <section class="person-page">
    <div class="page-head">
      <div>
        <h1 class="page-title">{person.name}</h1>
        <div class="meta-line">
          <span>{person.resultCount} resultater</span>
          <span>Første år {person.firstYear || "-"}</span>
          <span>Siste år {person.lastYear || "-"}</span>
        </div>
      </div>
    </div>

    <div class="summary-grid">
      <div class="summary-item">
        <span class="summary-label">PB 600 m</span>
        <span class="summary-value">{displayTime(person.pb["600"])}</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">PB 1200 m</span>
        <span class="summary-value">{displayTime(person.pb["1200"])}</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">År</span>
        <span class="summary-value">{person.years.length}</span>
      </div>
      <div class="summary-item">
        <span class="summary-label">Distanser</span>
        <span class="summary-value">{person.distances.join(" / ")}</span>
      </div>
    </div>

    <h2 class="section-title">Årsbeste</h2>
    <div class="table-wrap person-year-table">
      <table>
        <thead>
          <tr>
            <th class="col-distance">Distanse</th>
            {years.map((year) => <th class="num col-year">{year}</th>)}
            <th class="num col-time">PB</th>
          </tr>
        </thead>
        <tbody>
          {yearBestRows.map((row) => (
            <tr>
              <td class="col-distance">{row.distance} m</td>
              {years.map((year) => <td class="time num col-year">{displayTime(row.cells[year])}</td>)}
              <td class="time num col-time">{displayTime(row.pb)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="person-year-mobile">
      {yearBestRows.map((row) => {
        const entries = years
          .map((year) => ({ year, result: row.cells[year] }))
          .filter((entry) => entry.result);
        return (
          <div class="year-line">
            <strong>{row.distance} m</strong>
            {entries.length > 0 ? entries.map((entry) => (
              <span>{entry.year} {displayTime(entry.result)}</span>
            )) : <span class="subtle">Ingen resultater</span>}
            <b>PB {displayTime(row.pb)}</b>
          </div>
        );
      })}
    </div>

    <h2 class="section-title">Alle resultater</h2>
    <ResultTable results={personResults} showRank={false} sort={false} tableClass="result-table person-results" />

    <h2 class="section-title">Utvikling</h2>
    <div class="table-wrap">
      <table class="person-development-table">
        <thead>
          <tr>
            <th class="col-distance">Distanse</th>
            <th class="num col-first">Første gyldige</th>
            <th class="num col-time">Personlig beste</th>
            <th class="num col-diff">Forbedring</th>
          </tr>
        </thead>
        <tbody>
          {summaries.map((summary) => (
            <tr>
              <td class="col-distance">{summary.distance} m</td>
              <td class="time num col-first">{displayTime(summary.first)}</td>
              <td class="time num col-time">{displayTime(summary.best)}</td>
              <td class="num col-diff">{summary.delta ? `${summary.delta} sek` : "-"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
