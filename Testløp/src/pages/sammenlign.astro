---
import Layout from "../layouts/Layout.astro";
import results from "../data/results.json";
import stats from "../data/stats.json";

const years = stats.years;
const latest = stats.latestYear;
const fallback = stats.resultYears.find((year) => year !== latest) || stats.resultYears[0];
---

<Layout title="Sammenlign">
  <section data-comparison-page>
    <div class="page-head">
      <div>
        <h1 class="page-title">Sammenlign nivå</h1>
        <div class="meta-line">
          <span>Resultatlister mot hverandre</span>
          <span><span data-comparison-count-a>0</span> mot <span data-comparison-count-b>0</span> resultater</span>
        </div>
      </div>
    </div>

    <script type="application/json" id="results-data" set:html={JSON.stringify(results)}></script>
    <script type="application/json" id="years-data" set:html={JSON.stringify(years)}></script>

    <div class="toolbar" aria-label="Sammenligningsvalg">
      <label>År A
        <select class="select-input" name="yearA">
          {years.map((year) => <option value={year} selected={year === latest}>{year}</option>)}
        </select>
      </label>
      <label>År B
        <select class="select-input" name="yearB">
          {years.map((year) => <option value={year} selected={year === fallback}>{year}</option>)}
        </select>
      </label>
      <label>Distanse
        <select class="select-input" name="distance">
          <option value="600" selected>600 m</option>
          <option value="1200">1200 m</option>
        </select>
      </label>
      <label>Kjønn
        <select class="select-input" name="gender">
          <option>Alle</option>
          <option>Kvinner</option>
          <option selected>Menn</option>
        </select>
      </label>
      <label>Grunnlag
        <select class="select-input" name="mode">
          <option value="all" selected>Alle resultater</option>
          <option value="yearBest">Årsbeste per person</option>
        </select>
      </label>
    </div>

    <div class="level-summary surface" data-level-summary></div>
    <div data-level-sections></div>

    <div class="level-secondary" data-common-section>
      <h2 class="section-title">Samme personer i begge år</h2>
      <div class="table-wrap">
        <table class="comparison-common-table">
          <thead>
            <tr>
              <th class="col-name">Navn</th>
              <th class="col-gender">Kjønn</th>
              <th class="num col-time-a" data-common-year-a>År A</th>
              <th class="num col-time-b" data-common-year-b>År B</th>
              <th class="num col-diff">Endring</th>
            </tr>
          </thead>
          <tbody data-common-body></tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>
