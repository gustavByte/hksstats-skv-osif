---
import { displayTestlop, formatDate, genderShort, href, statusLabel, sortByTime, type ResultRow } from "../lib/format";

const { results, emptyText = "Ingen resultater." } = Astro.props as {
  results: ResultRow[];
  emptyText?: string;
  showRank?: boolean;
  sort?: boolean;
  tableClass?: string;
};

const showRank = Astro.props.showRank ?? true;
const shouldSort = Astro.props.sort ?? true;
const tableClass = Astro.props.tableClass ?? "result-table";
const rows = shouldSort ? sortByTime(results) : results;
---

{rows.length === 0 ? (
  <div class="empty-state">{emptyText}</div>
) : (
  <div class="table-wrap">
    <table class={tableClass}>
      <thead>
        <tr>
          {showRank && <th class="num col-rank" data-context-header>Plass</th>}
          <th class="col-name">Navn</th>
          <th class="num col-time">Tid</th>
          <th class="num col-year">År</th>
          <th class="col-distance">Distanse</th>
          <th class="col-gender">Kjønn</th>
          <th class="col-date">Dato</th>
          <th class="col-testlop">Testløp</th>
          <th class="col-note">Merknad</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((result, index) => (
          <tr
            data-person={result.personId}
            data-name={result.name}
            data-distance={String(result.distance)}
            data-gender={result.gender}
            data-group={`${result.distance} ${genderShort(result.gender)}`}
            data-time={result.timeSeconds ?? ""}
            data-valid={result.validToplist ? "true" : "false"}
            data-search={`${result.name} ${result.testlopId || ""} ${result.note || ""}`.toLowerCase()}
          >
            {showRank && <td class="num col-rank" data-rank>{result.timeSeconds == null ? "" : index + 1}</td>}
            <td class="name-cell col-name"><a href={href(`/person/${result.personId}/`)}>{result.name}</a></td>
            <td class="time num col-time">{result.timeDisplay || "-"}</td>
            <td class="num col-year">{result.year}</td>
            <td class="col-distance">{result.distance} m</td>
            <td class="col-gender">{result.gender}</td>
            <td class="col-date">
              <span>{formatDate(result.date)}</span>
              <span class="mobile-meta">{displayTestlop(result)}</span>
            </td>
            <td class="col-testlop">{displayTestlop(result)}</td>
            <td class="col-note">
              <span class="note-list">
                {result.note && <span class="badge warn">{result.note}</span>}
                {result.checkStatus !== "OK" && <span class="badge bad">{result.checkStatus}</span>}
                {!result.validToplist && <span class="badge warn">ikke off.</span>}
                {!statusLabel(result) && <span class="subtle">-</span>}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
