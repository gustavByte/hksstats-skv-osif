---
import Layout from "../layouts/Layout.astro";
import results from "../data/results.json";
import stats from "../data/stats.json";

const years = stats.years;
const latest = stats.latestYear;
const fallback = stats.resultYears.find((year) => year !== latest) || stats.resultYears[0];
---

<Layout title="Sammenlign">
  <section data-comparison-page>
    <div class="page-head">
      <div>
        <h1 class="page-title">Sammenlign</h1>
        <div class="meta-line">
          <span>Årsbeste per person</span>
          <span>Matrise side ved side</span>
        </div>
      </div>
    </div>

    <script type="application/json" id="results-data" set:html={JSON.stringify(results)}></script>
    <script type="application/json" id="years-data" set:html={JSON.stringify(years)}></script>

    <div class="toolbar" aria-label="A/B-sammenligning">
      <label>År A
        <select class="select-input" name="yearA">
          {years.map((year) => <option value={year} selected={year === latest}>{year}</option>)}
        </select>
      </label>
      <label>År B
        <select class="select-input" name="yearB">
          {years.map((year) => <option value={year} selected={year === fallback}>{year}</option>)}
        </select>
      </label>
      <label>Distanse
        <select class="select-input" name="distance">
          <option value="600" selected>600 m</option>
          <option value="1200">1200 m</option>
        </select>
      </label>
      <label>Kjønn
        <select class="select-input" name="gender">
          <option>Alle</option>
          <option>Kvinner</option>
          <option>Menn</option>
        </select>
      </label>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Navn</th>
            <th>Kjønn</th>
            <th class="num">År A</th>
            <th class="num">År B</th>
            <th class="num">Endring</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody data-ab-body></tbody>
      </table>
    </div>

    <h2 class="section-title">Årsmatrise</h2>
    <div class="toolbar" aria-label="Matrisevalg">
      <label>Distanse
        <select class="select-input" name="matrixDistance">
          <option value="600" selected>600 m</option>
          <option value="1200">1200 m</option>
        </select>
      </label>
      <label>Kjønn
        <select class="select-input" name="matrixGender">
          <option selected>Kvinner</option>
          <option>Menn</option>
        </select>
      </label>
    </div>

    <div class="table-wrap">
      <table>
        <thead data-matrix-head></thead>
        <tbody data-matrix-body></tbody>
      </table>
    </div>
  </section>
</Layout>
